DATABASE_URL=sqlite:///data/market.db

# Authentication — REQUIRED. There is no default on purpose: unset, or shorter
# than 12 characters, makes every protected route answer 503 rather than serving
# your holdings to anyone with the URL. Changing it invalidates every live session
# (the signing key is derived from it), which is what makes rotation real.
AUTH_PASSWORD=
AUTH_SESSION_DAYS=30
AUTH_COOKIE_SECURE=true
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=300

# Indicator history requirements. 1.0 = strict: a MA200 needs 200 séances. Lower
# it only deliberately; it is floored at 0.75 in code, so no value here can bring
# back the defect where ten séances were reported as a MA200.
MA_MIN_COVERAGE=1.0
HTTP_TIMEOUT_SECONDS=20
HTTP_RETRIES=3
HTTP_VERIFY_SSL=true
HTTP_ALLOW_INSECURE_SOURCE_RETRY=false
LOG_LEVEL=INFO
MIN_OPPORTUNITY_SCORE=80

# Database backups (nightly 22:00). The DB is the only asset that cannot be
# rebuilt: the history endpoint only re-serves a ~3-year rolling window.
# These copies live on the SAME volume as the database, so they answer logical
# damage (bad backfill, botched migration) but NOT the loss of the volume itself.
# There is no off-host copy — download data/backups/ periodically if that matters.
BACKUP_DIR=data/backups
BACKUP_KEEP=7

# Portfolio holdings (the actions you actually own).
# Use the file locally; on the deployed service set PORTFOLIO_JSON as a private
# secret instead, so buy prices never reach the repo.
PORTFOLIO_FILE=config/portfolio.json
# PORTFOLIO_JSON={"fee_rate":0.005,"holdings":[{"symbol":"ATW","quantity":10,"buy_price":410}]}
TRADING_FEE_RATE=0.005

# Sell/hold advice thresholds.
TAKE_PROFIT_PCT=15
STOP_LOSS_PCT=-8
SELL_AVOID_SCORE=60
WEAK_MOMENTUM_PCT=-3

# Intraday urgent alert (held stocks only).
URGENT_CRASH_PCT=-5
MOROCCO_UTC_OFFSET=1

# Web app + in-process scheduler (used by `cli serve`).
TIMEZONE=Africa/Casablanca
ENABLE_SCHEDULER=true

# Web Push (PWA notifications). Generate with: python -m moroccan_stock_intelligence.cli gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
