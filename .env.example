TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token
TELEGRAM_CHAT_ID=123456789
DATABASE_URL=sqlite:///data/market.db
HTTP_TIMEOUT_SECONDS=20
HTTP_RETRIES=3
HTTP_VERIFY_SSL=true
HTTP_ALLOW_INSECURE_SOURCE_RETRY=false
LOG_LEVEL=INFO
WATCHLIST_FILE=config/watchlist.json
MIN_OPPORTUNITY_SCORE=80

# Portfolio holdings (the actions you actually own).
# Use the file locally; in GitHub Actions set PORTFOLIO_JSON as a private secret instead.
PORTFOLIO_FILE=config/portfolio.json
# PORTFOLIO_JSON={"fee_rate":0.005,"holdings":[{"symbol":"ATW","quantity":10,"buy_price":410}]}
TRADING_FEE_RATE=0.005

# Sell/hold advice thresholds.
TAKE_PROFIT_PCT=15
STOP_LOSS_PCT=-8
SELL_AVOID_SCORE=60
WEAK_MOMENTUM_PCT=-3

# Intraday urgent alert (held stocks only).
URGENT_CRASH_PCT=-5
MOROCCO_UTC_OFFSET=1
