alert_state.json
test_alert_state.json
config/portfolio.json
__pycache__/
.env
data/
.pytest_cache/
.ruff_cache/
.venv/
*.pyc

# Flutter intermediate build artifacts (the shipped output lives in webapp_flutter/)
flutter_app/build/
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies

# Alembic
migrations/versions/__pycache__/

# Coverage artefacts. `.coverage` is a binary SQLite file rewritten by every
# pytest-cov run, so tracking it guaranteed a conflict on every merge while
# telling a reader nothing — the number that matters is reported by CI.
.coverage
.coverage.*
coverage.xml
htmlcov/

# Build-time CA certificates (see ci/certs/README.md). The directory is tracked so
# the Dockerfile's COPY always succeeds; its contents never are — a CA in an image
# layer is shipped to everyone who pulls it.
ci/certs/*.crt
ci/certs/*.pem
