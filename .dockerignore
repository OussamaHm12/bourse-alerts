.venv
**/__pycache__
*.pyc
.git
.gitignore
data
*.db
node_modules

# flutter_app/ is NO LONGER excluded wholesale: the image now compiles the web
# bundle from source in a build stage (see Dockerfile), which is what stops the
# served bundle drifting from the code under review. Excluding it made that COPY
# fail with "/flutter_app: not found" — correct for the old design, fatal for
# this one.
#
# Its build artefacts stay excluded: large, machine-specific, and regenerated by
# the build stage anyway.
flutter_app/build
flutter_app/.dart_tool
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
